<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Daily Four · Four is the Magic Number</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet" />
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg:       #0c1d3a;
  --surface:  #112247;
  --border:   #1e3a6e;
  --text:     #e8f3fd;
  --muted:    #7ba3cc;
  --dim:      #3a5f8a;
  --accent:   #a8d4f5;
  --green:    #6dd5a8;
  --yellow:   #f5d76e;
  --red:      #e07878;
  --purple:   #b48eda;
  --glow:     0 0 18px rgba(168,212,245,0.28), 0 0 50px rgba(168,212,245,0.1);

  --g-yellow-bg:  rgba(245,215,110,0.18);
  --g-yellow-bd:  #f5d76e;
  --g-yellow-tx:  #f5d76e;
  --g-green-bg:   rgba(109,213,168,0.18);
  --g-green-bd:   #6dd5a8;
  --g-green-tx:   #6dd5a8;
  --g-blue-bg:    rgba(168,212,245,0.18);
  --g-blue-bd:    #a8d4f5;
  --g-blue-tx:    #a8d4f5;
  --g-purple-bg:  rgba(180,142,218,0.18);
  --g-purple-bd:  #b48eda;
  --g-purple-tx:  #b48eda;
}

html { scroll-behavior: smooth; }

html, body {
  min-height: 100vh;
  background-color: var(--bg);
  background-image:
    linear-gradient(rgba(168,212,245,0.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(168,212,245,0.045) 1px, transparent 1px);
  background-size: 44px 44px;
  color: var(--text);
  font-family: 'JetBrains Mono', monospace;
  overflow-x: hidden;
}

/* ghost 4 */
.ghost-four {
  position: fixed; inset: 0;
  display: flex; align-items: center; justify-content: center;
  pointer-events: none; z-index: 0; overflow: hidden;
}
.ghost-four span {
  font-family: 'Cinzel', serif;
  font-size: clamp(60vw, 80vw, 90vh);
  font-weight: 900; color: transparent;
  -webkit-text-stroke: 1px rgba(168,212,245,0.07);
  user-select: none; line-height: 1;
  animation: breathe 8s ease-in-out infinite;
}
@keyframes breathe {
  0%, 100% { opacity: 0.7; transform: scale(1); }
  50%      { opacity: 1;   transform: scale(1.015); }
}

/* layout */
.section {
  position: relative; z-index: 1;
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 2.5rem 1.5rem 3rem;
}
.how-section {
  background: rgba(8,16,34,0.6);
  border-top: 1px solid var(--border);
  justify-content: flex-start; padding-top: 4rem;
}
.wrap { width: 100%; max-width: 520px; display: flex; flex-direction: column; gap: 1.25rem; }

/* header */
header { text-align: center; }
.header-bar { display: flex; align-items: center; justify-content: center; gap: 1rem; position: relative; }
.eyebrow {
  font-size: 0.62rem; letter-spacing: 0.4em; text-transform: uppercase;
  color: var(--dim); margin-bottom: 0.75rem;
}
h1 {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 700;
  letter-spacing: 0.05em; color: var(--text); line-height: 1.15;
  text-shadow: var(--glow); margin-bottom: 0.4rem;
}
h1 em { font-style: normal; color: var(--accent); }
.date-label {
  font-size: 0.65rem; color: var(--muted);
  letter-spacing: 0.2em; text-transform: uppercase;
}
.icon-btn {
  background: none; border: 1px solid var(--border); color: var(--muted);
  width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;
  cursor: pointer; font-size: 1rem; transition: border-color 0.2s, color 0.2s;
}
.icon-btn:hover { border-color: var(--accent); color: var(--accent); }
.header-icons { position: absolute; right: 0; top: 50%; transform: translateY(-50%); display: flex; gap: 0.5rem; }
.rule { border: none; border-top: 1px solid var(--border); }

/* ── SOLVED GROUPS ── */
.solved-groups { display: flex; flex-direction: column; gap: 0.5rem; }
.solved-row {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.7rem 1rem; border: 1px solid;
  animation: groupReveal 0.5s ease forwards;
}
@keyframes groupReveal {
  0%   { opacity: 0; transform: scaleY(0.3); }
  100% { opacity: 1; transform: scaleY(1); }
}
.solved-row.yellow { background: var(--g-yellow-bg); border-color: var(--g-yellow-bd); }
.solved-row.green  { background: var(--g-green-bg);  border-color: var(--g-green-bd); }
.solved-row.blue   { background: var(--g-blue-bg);   border-color: var(--g-blue-bd); }
.solved-row.purple { background: var(--g-purple-bg);  border-color: var(--g-purple-bd); }
.solved-label {
  font-family: 'Cinzel', serif; font-size: 0.6rem;
  letter-spacing: 0.2em; text-transform: uppercase;
  white-space: nowrap; min-width: 90px;
}
.solved-row.yellow .solved-label { color: var(--g-yellow-tx); }
.solved-row.green  .solved-label { color: var(--g-green-tx); }
.solved-row.blue   .solved-label { color: var(--g-blue-tx); }
.solved-row.purple .solved-label { color: var(--g-purple-tx); }
.solved-nums {
  font-size: 0.85rem; font-weight: 700; color: var(--text);
  letter-spacing: 0.08em;
}

/* ── TILE GRID ── */
.grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 0.5rem;
}
.tile {
  aspect-ratio: 1.4;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--border); background: var(--surface);
  font-family: 'JetBrains Mono', monospace;
  font-size: clamp(0.9rem, 2.5vw, 1.1rem); font-weight: 700;
  color: var(--text); cursor: pointer;
  transition: background 0.15s, border-color 0.15s, transform 0.15s;
  user-select: none; -webkit-tap-highlight-color: transparent;
}
.tile:hover { border-color: var(--dim); background: rgba(168,212,245,0.05); }
.tile.selected {
  background: rgba(168,212,245,0.15); border-color: var(--accent);
  color: var(--accent); transform: scale(0.96);
}
.tile.shake {
  animation: tileShake 0.45s ease;
}
@keyframes tileShake {
  0%,100% { transform: translateX(0); }
  15% { transform: translateX(-5px); }
  35% { transform: translateX(5px); }
  55% { transform: translateX(-3px); }
  75% { transform: translateX(3px); }
}
.tile.pop {
  animation: tilePop 0.35s ease;
}
@keyframes tilePop {
  0%   { transform: scale(1); }
  50%  { transform: scale(1.12); }
  100% { transform: scale(1); }
}

/* ── CONTROLS ── */
.controls { display: flex; justify-content: center; gap: 0.6rem; flex-wrap: wrap; }
.ctrl-btn {
  padding: 0.55rem 1.2rem; background: transparent;
  font-family: 'Cinzel', serif; font-size: 0.62rem;
  letter-spacing: 0.2em; text-transform: uppercase;
  cursor: pointer; transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.ctrl-btn.primary { border: 1px solid var(--accent); color: var(--accent); }
.ctrl-btn.primary:hover { background: rgba(168,212,245,0.1); color: var(--text); }
.ctrl-btn.primary:disabled { opacity: 0.3; cursor: default; pointer-events: none; }
.ctrl-btn.secondary { border: 1px solid var(--border); color: var(--muted); }
.ctrl-btn.secondary:hover { background: rgba(168,212,245,0.05); border-color: var(--dim); }

/* ── MISTAKES ── */
.mistakes-bar { display: flex; align-items: center; justify-content: center; gap: 0.5rem; min-height: 1.5rem; }
.mistakes-label { font-size: 0.6rem; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; }
.mistake-dots { display: flex; gap: 0.35rem; }
.mistake-dot {
  width: 12px; height: 12px; border-radius: 50%;
  background: var(--dim); transition: background 0.3s;
}
.mistake-dot.used { background: var(--red); }

/* ── TOAST ── */
.toast {
  position: fixed; top: 5rem; left: 50%; transform: translateX(-50%);
  background: var(--text); color: var(--bg); padding: 0.6rem 1.4rem;
  font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; font-weight: 700;
  z-index: 100; opacity: 0; pointer-events: none;
  transition: opacity 0.3s;
}
.toast.show { opacity: 1; }

/* ── END STATE ── */
#endState {
  display: none; flex-direction: column; align-items: center; gap: 1.25rem;
  text-align: center; padding: 1.75rem 1.5rem;
  border: 1px solid var(--border); background: var(--surface);
  position: relative; overflow: hidden;
}
#endState::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(168,212,245,0.04) 0%, transparent 60%);
  pointer-events: none;
}
#endState.show { display: flex; }
.end-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.2rem, 4vw, 1.6rem);
  color: var(--accent); text-shadow: var(--glow); font-weight: 700;
}
.end-emojis { font-size: 1.6rem; letter-spacing: 0.12em; line-height: 1.5; }
.end-buttons { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; }
.copy-btn {
  padding: 0.65rem 1.8rem; background: transparent;
  border: 1px solid var(--dim); color: var(--accent);
  font-family: 'Cinzel', serif; font-size: 0.72rem;
  letter-spacing: 0.25em; text-transform: uppercase;
  cursor: pointer; transition: background 0.2s, color 0.2s, border-color 0.2s;
}
.copy-btn:hover { background: rgba(168,212,245,0.08); border-color: var(--accent); color: var(--text); }
.copy-btn.copied { border-color: var(--green); color: var(--green); }
.countdown { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; min-height: 1.2em; }

/* ── STATS MODAL ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(8,16,34,0.85);
  z-index: 200; display: none; align-items: center; justify-content: center;
  padding: 1.5rem;
}
.modal-overlay.show { display: flex; }
.modal {
  background: var(--surface); border: 1px solid var(--border);
  width: 100%; max-width: 400px; padding: 2rem 1.5rem;
  position: relative; max-height: 90vh; overflow-y: auto;
}
.modal-close {
  position: absolute; top: 0.75rem; right: 0.75rem;
  background: none; border: none; color: var(--muted); font-size: 1.2rem;
  cursor: pointer; line-height: 1;
}
.modal-close:hover { color: var(--text); }
.modal-title {
  font-family: 'Cinzel', serif; font-size: 1.1rem;
  letter-spacing: 0.1em; color: var(--text);
  text-align: center; margin-bottom: 1.5rem;
}
.stats-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 0.5rem; text-align: center; margin-bottom: 1.5rem;
}
.stat-num { font-size: 1.4rem; font-weight: 700; color: var(--accent); }
.stat-label { font-size: 0.55rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }
.dist-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
.dist-label { font-size: 0.7rem; color: var(--muted); width: 1.2rem; text-align: right; }
.dist-bar-wrap { flex: 1; height: 20px; }
.dist-bar {
  height: 100%; min-width: 20px;
  display: flex; align-items: center; justify-content: flex-end;
  padding-right: 0.4rem;
  font-size: 0.6rem; font-weight: 700; color: var(--bg);
  background: var(--dim); transition: width 0.5s;
}
.dist-bar.highlight { background: var(--accent); }

/* ── TUTORIAL MODAL ── */
.tutorial-body { display: flex; flex-direction: column; gap: 1.5rem; }
.tut-step { display: none; flex-direction: column; gap: 0.75rem; text-align: center; }
.tut-step.active { display: flex; }
.tut-step h3 {
  font-family: 'Cinzel', serif; font-size: 0.9rem;
  color: var(--accent); letter-spacing: 0.08em;
}
.tut-step p { font-size: 0.78rem; color: var(--muted); line-height: 1.7; }
.tut-chain {
  display: flex; align-items: center; justify-content: center;
  gap: 0.4rem; font-size: 1rem; font-weight: 700; color: var(--text);
  padding: 0.75rem 0;
}
.tut-chain .arr { color: var(--dim); font-size: 0.75rem; }
.tut-chain .magic { color: var(--accent); text-shadow: var(--glow); }
.tut-grid-demo {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 0.35rem; max-width: 220px; margin: 0.5rem auto;
}
.tut-grid-demo .mini-tile {
  aspect-ratio: 1.2; display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--border); background: var(--surface);
  font-size: 0.65rem; font-weight: 700; color: var(--text);
}
.tut-nav { display: flex; justify-content: center; gap: 0.75rem; margin-top: 0.5rem; }

/* scroll hint */
.scroll-hint { text-align: center; }
.scroll-hint a {
  font-size: 0.6rem; color: var(--dim); letter-spacing: 0.2em;
  text-transform: uppercase; text-decoration: none; transition: color 0.2s;
}
.scroll-hint a:hover { color: var(--muted); }

/* how section reuse */
.section-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.2rem, 3vw, 1.8rem); font-weight: 700;
  letter-spacing: 0.05em; color: var(--text);
  text-shadow: var(--glow); text-align: center; margin-bottom: 0.5rem;
}
.section-sub { font-size: 0.75rem; color: var(--muted); line-height: 1.8; letter-spacing: 0.03em; text-align: center; }
.explorer { display: flex; flex-direction: column; gap: 0.75rem; }
.explorer-label { font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--dim); }
.explorer-row {
  display: flex; border: 1px solid var(--border);
  background: var(--surface); transition: border-color 0.25s;
}
.explorer-row:focus-within { border-color: var(--dim); }
.explorer-input {
  flex: 1; min-width: 0; background: transparent; border: none; outline: none;
  padding: 0.75rem 1rem; font-family: 'JetBrains Mono', monospace;
  font-size: 1rem; color: var(--text); caret-color: var(--accent);
  -moz-appearance: textfield;
}
.explorer-input::-webkit-inner-spin-button,
.explorer-input::-webkit-outer-spin-button { -webkit-appearance: none; }
.explorer-input::placeholder { color: var(--dim); font-style: italic; }
.explorer-go {
  padding: 0.75rem 1.1rem; background: transparent; border: none;
  border-left: 1px solid var(--border); color: var(--accent);
  font-family: 'Cinzel', serif; font-size: 0.6rem;
  letter-spacing: 0.25em; text-transform: uppercase;
  cursor: pointer; transition: background 0.2s; white-space: nowrap; flex-shrink: 0;
}
.explorer-go:hover { background: rgba(168,212,245,0.08); }
.explorer-result {
  font-size: 0.78rem; color: var(--muted); min-height: 1.6em;
  line-height: 2; font-style: italic;
}
.explorer-result .num { color: var(--text); font-style: normal; font-weight: 700; }
.explorer-result .magic { color: var(--accent); font-style: normal; font-weight: 700; font-size: 1.05em; text-shadow: var(--glow); }
.explain-block {
  border: 1px solid var(--border); background: var(--surface);
  padding: 1.25rem 1.5rem; font-size: 0.8rem; color: var(--muted);
  line-height: 1.9; letter-spacing: 0.02em; position: relative; overflow: hidden;
}
.explain-block::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(168,212,245,0.03) 0%, transparent 60%);
  pointer-events: none;
}
.explain-block strong { color: var(--text); font-weight: 700; }
.explain-block em { color: var(--accent); font-style: normal; }
footer {
  text-align: center; font-size: 0.6rem; color: var(--dim);
  letter-spacing: 0.15em; line-height: 2;
  padding-top: 1rem; border-top: 1px solid var(--border);
}
footer a { color: var(--dim); text-decoration: none; transition: color 0.2s; }
footer a:hover { color: var(--muted); }

/* responsive */
@media (max-width: 600px) {
  .tile { font-size: 0.85rem; }
  .solved-label { font-size: 0.55rem; min-width: 70px; }
  .solved-nums { font-size: 0.75rem; }
}
@media (max-width: 380px) {
  .grid { gap: 0.35rem; }
  .tile { font-size: 0.78rem; }
  .ctrl-btn { padding: 0.45rem 0.8rem; font-size: 0.55rem; }
}
</style>
</head>
<body>

<div class="ghost-four" aria-hidden="true"><span>4</span></div>

<!-- ── TOAST ── -->
<div class="toast" id="toast"></div>

<!-- ── PUZZLE SECTION ── -->
<section class="section">
  <div class="wrap">
    <header>
      <div class="header-bar">
        <div></div>
        <div style="text-align:center">
          <p class="eyebrow">FOUR &middot; #<span id="dayNum">&mdash;</span></p>
          <h1>Daily <em>Four</em></h1>
          <p class="date-label" id="dateLabel">&mdash;</p>
        </div>
        <div class="header-icons">
          <button class="icon-btn" id="helpBtn" title="How to play" aria-label="How to play">?</button>
          <button class="icon-btn" id="statsBtn" title="Statistics" aria-label="Statistics">&#x2261;</button>
        </div>
      </div>
    </header>
    <hr class="rule" />

    <div id="solvedGroups" class="solved-groups"></div>
    <div id="tileGrid" class="grid"></div>

    <div class="controls" id="controls">
      <button class="ctrl-btn secondary" id="shuffleBtn" onclick="shuffleTiles()">Shuffle</button>
      <button class="ctrl-btn secondary" id="deselectBtn" onclick="deselectAll()">Deselect</button>
      <button class="ctrl-btn primary" id="submitBtn" onclick="submitGuess()" disabled>Submit</button>
    </div>

    <div class="mistakes-bar" id="mistakesBar">
      <span class="mistakes-label">Mistakes remaining</span>
      <div class="mistake-dots" id="mistakeDots"></div>
    </div>

    <div id="endState">
      <div class="end-title" id="endTitle"></div>
      <div class="end-emojis" id="endEmojis"></div>
      <div class="end-buttons">
        <button class="copy-btn" id="copyBtn" onclick="copyResult()">Share</button>
        <button class="copy-btn" id="viewStatsBtn" onclick="openStats()">Stats</button>
      </div>
      <div class="countdown" id="countdown"></div>
    </div>

    <hr class="rule" />
    <div class="scroll-hint">
      <a href="#howSection">how does this work? &darr;</a>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ── -->
<section class="section how-section" id="howSection">
  <div class="wrap">
    <header>
      <h2 class="section-title">How does this work?</h2>
      <p class="section-sub">Every number eventually leads to 4. Try one and see.</p>
    </header>
    <hr class="rule" />
    <div class="explorer">
      <span class="explorer-label">Enter any number</span>
      <div class="explorer-row">
        <input class="explorer-input" type="number" id="explorerInput" placeholder="try 23, 100, 999&hellip;" min="1" inputmode="numeric" pattern="[0-9]*" />
        <button class="explorer-go" onclick="exploreNumber()">Go &rarr;</button>
      </div>
      <div class="explorer-result" id="explorerResult">&mdash;</div>
    </div>
    <div class="explain-block">
      Count the letters in any number&rsquo;s name. <strong>Five</strong> has <em>4</em> letters &mdash; done.
      <strong>Seven</strong> has <em>5</em> letters &rarr; <strong>five</strong> has <em>4</em>.
      Keep going and you always land on <em>four</em>, because <strong>four</strong> is the only number
      whose letter count equals itself. It is the fixed point. The magic number.
    </div>
    <hr class="rule" />
    <footer>
      <a href="/magic">explore more &rarr;</a><br>
      christopherjharper.com
    </footer>
  </div>
</section>

<!-- ── STATS MODAL ── -->
<div class="modal-overlay" id="statsModal">
  <div class="modal">
    <button class="modal-close" onclick="closeStats()">&times;</button>
    <div class="modal-title">Statistics</div>
    <div class="stats-grid">
      <div><div class="stat-num" id="statPlayed">0</div><div class="stat-label">Played</div></div>
      <div><div class="stat-num" id="statWin">0</div><div class="stat-label">Win %</div></div>
      <div><div class="stat-num" id="statStreak">0</div><div class="stat-label">Streak</div></div>
      <div><div class="stat-num" id="statMax">0</div><div class="stat-label">Max</div></div>
    </div>
    <div class="modal-title" style="font-size:0.8rem;margin-bottom:0.75rem">Mistake Distribution</div>
    <div id="distChart"></div>
  </div>
</div>

<!-- ── TUTORIAL MODAL ── -->
<div class="modal-overlay" id="tutorialModal">
  <div class="modal" style="max-width:440px">
    <button class="modal-close" onclick="closeTutorial()">&times;</button>
    <div class="tutorial-body">
      <div class="tut-step active" id="tutStep0">
        <h3>Every Number Leads to Four</h3>
        <p>Take any number. Count the letters in its name. Repeat until you reach <strong style="color:var(--accent)">four</strong>.</p>
        <div class="tut-chain">
          <span>7</span><span class="arr">→</span>
          <span>5</span><span class="arr">→</span>
          <span class="magic">4</span>
        </div>
        <p><strong style="color:var(--text)">seven</strong> has 5 letters → <strong style="color:var(--text)">five</strong> has 4 → done!</p>
      </div>
      <div class="tut-step" id="tutStep1">
        <h3>Chain Length</h3>
        <p>The <strong style="color:var(--accent)">chain length</strong> is how many steps it takes to reach four.</p>
        <div class="tut-chain">
          <span>11</span><span class="arr">→</span>
          <span>6</span><span class="arr">→</span>
          <span>3</span><span class="arr">→</span>
          <span>5</span><span class="arr">→</span>
          <span class="magic">4</span>
        </div>
        <p>11 → 6 → 3 → 5 → 4&ensp;=&ensp;<strong style="color:var(--accent)">4 steps</strong></p>
      </div>
      <div class="tut-step" id="tutStep2">
        <h3>Group by Chain Length</h3>
        <p>You'll see 16 numbers. Find 4 groups of 4 that share the same chain length.</p>
        <div class="tut-grid-demo">
          <div class="mini-tile">7</div><div class="mini-tile">11</div>
          <div class="mini-tile">23</div><div class="mini-tile">3</div>
          <div class="mini-tile">15</div><div class="mini-tile">100</div>
          <div class="mini-tile">70</div><div class="mini-tile">80</div>
          <div class="mini-tile" style="border-color:var(--g-yellow-bd)">5</div>
          <div class="mini-tile" style="border-color:var(--g-yellow-bd)">9</div>
          <div class="mini-tile" style="border-color:var(--g-yellow-bd)">40</div>
          <div class="mini-tile" style="border-color:var(--g-yellow-bd)">50</div>
          <div class="mini-tile">373</div><div class="mini-tile">12</div>
          <div class="mini-tile">300</div><div class="mini-tile">777</div>
        </div>
      </div>
      <div class="tut-step" id="tutStep3">
        <h3>You Have 4 Chances</h3>
        <p>Select 4 numbers and submit. If they share a chain length, the group reveals.<br>
        Make 4 wrong guesses and it's game over.</p>
        <p style="color:var(--accent);font-weight:700;font-size:0.85rem;margin-top:0.5rem">Good luck!</p>
      </div>
      <div class="tut-nav">
        <button class="ctrl-btn secondary" id="tutPrev" onclick="tutorialNav(-1)">Back</button>
        <button class="ctrl-btn primary" id="tutNext" onclick="tutorialNav(1)">Next</button>
      </div>
    </div>
  </div>
</div>

<script>
/* ══════════════════════════════════════════════════════════
   CHAIN LOGIC
   ══════════════════════════════════════════════════════════ */
const ONEs = ['zero','one','two','three','four','five','six','seven','eight','nine','ten','eleven','twelve','thirteen','fourteen','fifteen','sixteen','seventeen','eighteen','nineteen'];
const TENs = ['','','twenty','thirty','forty','fifty','sixty','seventy','eighty','ninety'];

function toWords(n) {
  if (n < 0)    return 'negative ' + toWords(-n);
  if (n < 20)   return ONEs[n];
  if (n < 100)  { const t = TENs[Math.floor(n/10)], o = n%10; return o ? t+'-'+ONEs[o] : t; }
  if (n < 1000) { const h = Math.floor(n/100), r = n%100; return ONEs[h]+' hundred'+(r ? ' '+toWords(r) : ''); }
  if (n < 10000){ const k = Math.floor(n/1000), r = n%1000; return toWords(k)+' thousand'+(r ? ' '+toWords(r) : ''); }
  return n.toString();
}

function letterCount(n) {
  return toWords(Math.abs(n)).replace(/[^a-z]/gi,'').length;
}

function buildChain(n) {
  const steps = [], seen = new Set();
  let cur = n;
  while (true) {
    if (seen.has(cur) || steps.length > 30) break;
    seen.add(cur);
    const cnt = letterCount(cur);
    steps.push({ value: cur, count: cnt });
    if (cnt === 4) break;
    cur = cnt;
  }
  return steps;
}

function chainLength(n) {
  return buildChain(n).length - 1;
}

/* ══════════════════════════════════════════════════════════
   SEEDED PRNG
   ══════════════════════════════════════════════════════════ */
function mulberry32(seed) {
  return function() {
    seed |= 0; seed = seed + 0x6D2B79F5 | 0;
    let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

const EPOCH = new Date('2025-01-01T00:00:00Z').getTime();
function getDayNumber() { return Math.floor((Date.now() - EPOCH) / 86400000); }
function todayStr() {
  const d = new Date();
  return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
}

/* ══════════════════════════════════════════════════════════
   PUZZLE GENERATION
   ══════════════════════════════════════════════════════════ */
const POOLS = { 2: [], 3: [], 4: [], 5: [] };
(function buildPools() {
  for (let n = 1; n <= 9999; n++) {
    if (n === 4) continue;
    const cl = chainLength(n);
    if (POOLS[cl] !== undefined) POOLS[cl].push(n);
  }
})();

const GROUP_META = [
  { color: 'yellow', emoji: '🟨' },
  { color: 'green',  emoji: '🟩' },
  { color: 'blue',   emoji: '🟦' },
  { color: 'purple', emoji: '🟪' },
];

function seededShuffle(arr, rng) {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(rng() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function generatePuzzle(dayNumber) {
  const rng = mulberry32(dayNumber * 1000003 + 7919);

  // Chain 3 is always purple (hardest — rarest, most deceptive).
  // Rotate chain lengths 2, 4, 5 across yellow/green/blue for daily variety.
  const others = [2, 4, 5];
  const offset = dayNumber % 3;
  const rotated = [];
  for (let i = 0; i < 3; i++) rotated.push(others[(i + offset) % 3]);
  const assignments = [...rotated, 3]; // [yellow, green, blue, purple]

  const groups = [];
  const usedValues = new Set();

  for (let gi = 0; gi < 4; gi++) {
    const cl = assignments[gi];
    const pool = POOLS[cl];
    const shuffled = seededShuffle(pool, rng);

    // Magnitude-diverse selection: try one from each size bucket
    const buckets = [
      shuffled.filter(v => v >= 1 && v <= 20),
      shuffled.filter(v => v >= 21 && v <= 99),
      shuffled.filter(v => v >= 100 && v <= 999),
      shuffled.filter(v => v >= 1000 && v <= 9999),
    ];

    const picked = [];
    for (const bucket of buckets) {
      for (const v of bucket) {
        if (!usedValues.has(v) && !picked.includes(v)) {
          picked.push(v); usedValues.add(v); break;
        }
      }
    }
    // Fill remaining from full pool
    if (picked.length < 4) {
      for (const v of shuffled) {
        if (picked.length >= 4) break;
        if (!usedValues.has(v) && !picked.includes(v)) {
          picked.push(v); usedValues.add(v);
        }
      }
    }

    groups.push({
      chainLength: cl,
      numbers: picked,
      ...GROUP_META[gi],
      label: cl + (cl === 1 ? ' step' : ' steps') + ' to four',
    });
  }

  return groups;
}

/* ══════════════════════════════════════════════════════════
   GAME STATE
   ══════════════════════════════════════════════════════════ */
const MAX_MISTAKES = 4;
const STORAGE_KEY = () => 'four-connect-' + todayStr();
const STATS_KEY = 'four-stats';

let puzzle = [];
let tiles = [];
let selected = new Set();
let solvedGroups = [];
let solveOrder = [];
let mistakes = 0;
let gameOver = false;
let won = false;
let dayNumber = 0;
let previousGuesses = [];

function loadGameState() {
  try {
    const s = JSON.parse(localStorage.getItem(STORAGE_KEY()));
    if (!s || s.date !== todayStr()) return null;
    return s;
  } catch(e) { return null; }
}

function saveGameState() {
  const s = {
    date: todayStr(),
    solvedGroupIndices: solvedGroups.map(g => puzzle.indexOf(g)),
    solveOrder: solveOrder.slice(),
    mistakes,
    gameOver,
    won,
    previousGuesses: previousGuesses.slice(),
  };
  try { localStorage.setItem(STORAGE_KEY(), JSON.stringify(s)); } catch(e) {}
}

/* ══════════════════════════════════════════════════════════
   STATS
   ══════════════════════════════════════════════════════════ */
function loadStats() {
  try {
    const s = JSON.parse(localStorage.getItem(STATS_KEY));
    return s || defaultStats();
  } catch(e) { return defaultStats(); }
}
function defaultStats() {
  return { played: 0, wins: 0, streak: 0, maxStreak: 0, dist: [0,0,0,0,0], lastDate: null };
}
function saveStats(stats) {
  try { localStorage.setItem(STATS_KEY, JSON.stringify(stats)); } catch(e) {}
}
function recordGame(didWin, mistakeCount) {
  const stats = loadStats();
  if (stats.lastDate === todayStr()) return;
  stats.played++;
  if (didWin) {
    stats.wins++;
    stats.streak++;
    if (stats.streak > stats.maxStreak) stats.maxStreak = stats.streak;
    stats.dist[mistakeCount] = (stats.dist[mistakeCount] || 0) + 1;
  } else {
    stats.streak = 0;
  }
  stats.lastDate = todayStr();
  saveStats(stats);
}

/* ══════════════════════════════════════════════════════════
   RENDER
   ══════════════════════════════════════════════════════════ */
function renderSolvedGroups() {
  const el = document.getElementById('solvedGroups');
  el.innerHTML = '';
  for (const g of solvedGroups) {
    const row = document.createElement('div');
    row.className = 'solved-row ' + g.color;
    row.innerHTML =
      '<span class="solved-label">' + g.label + '</span>' +
      '<span class="solved-nums">' + g.numbers.slice().sort((a,b) => a-b).join(' &ensp; ') + '</span>';
    el.appendChild(row);
  }
}

function renderGrid() {
  const grid = document.getElementById('tileGrid');
  grid.innerHTML = '';
  if (gameOver) { grid.style.display = 'none'; return; }
  grid.style.display = 'grid';
  grid.style.gridTemplateRows = 'repeat(' + Math.ceil(tiles.length / 4) + ', 1fr)';

  for (const num of tiles) {
    const tile = document.createElement('div');
    tile.className = 'tile';
    tile.textContent = num;
    tile.dataset.value = num;
    if (selected.has(num)) tile.classList.add('selected');
    tile.addEventListener('click', () => toggleTile(num));
    grid.appendChild(tile);
  }
}

function renderMistakes() {
  const bar = document.getElementById('mistakesBar');
  if (gameOver) { bar.style.display = 'none'; return; }
  bar.style.display = 'flex';
  const dots = document.getElementById('mistakeDots');
  dots.innerHTML = '';
  for (let i = 0; i < MAX_MISTAKES; i++) {
    const dot = document.createElement('div');
    dot.className = 'mistake-dot';
    if (i < mistakes) dot.classList.add('used');
    dots.appendChild(dot);
  }
}

function renderControls() {
  const el = document.getElementById('controls');
  el.style.display = gameOver ? 'none' : 'flex';
  document.getElementById('submitBtn').disabled = selected.size !== 4;
}

function render() {
  renderSolvedGroups();
  renderGrid();
  renderMistakes();
  renderControls();
}

/* ══════════════════════════════════════════════════════════
   GAME ACTIONS
   ══════════════════════════════════════════════════════════ */
function toggleTile(num) {
  if (gameOver) return;
  if (selected.has(num)) {
    selected.delete(num);
  } else {
    if (selected.size >= 4) return;
    selected.add(num);
  }
  renderGrid();
  renderControls();
}

function deselectAll() {
  selected.clear();
  renderGrid();
  renderControls();
}

function shuffleTiles() {
  for (let i = tiles.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [tiles[i], tiles[j]] = [tiles[j], tiles[i]];
  }
  renderGrid();
}

function submitGuess() {
  if (selected.size !== 4 || gameOver) return;

  const guess = Array.from(selected).sort((a,b) => a-b);
  const guessKey = guess.join(',');

  if (previousGuesses.includes(guessKey)) {
    showToast('Already guessed!');
    return;
  }

  // Check for match
  let matchGroup = null;
  for (const g of puzzle) {
    if (solvedGroups.includes(g)) continue;
    const gNums = g.numbers.slice().sort((a,b) => a-b);
    if (gNums.join(',') === guessKey) { matchGroup = g; break; }
  }

  if (matchGroup) {
    // Correct!
    solvedGroups.push(matchGroup);
    solveOrder.push(matchGroup.color);
    tiles = tiles.filter(t => !selected.has(t));
    selected.clear();
    saveGameState();

    // Pop animation then re-render
    const tileEls = document.querySelectorAll('.tile.selected');
    tileEls.forEach(el => { el.classList.remove('selected'); el.classList.add('pop'); });

    setTimeout(() => {
      render();
      if (solvedGroups.length === 4) {
        won = true; gameOver = true;
        saveGameState();
        recordGame(true, mistakes);
        setTimeout(() => showEndState(), 600);
      }
    }, 380);
  } else {
    // Wrong
    previousGuesses.push(guessKey);
    mistakes++;
    saveGameState();

    // "One away" check
    let oneAway = false;
    for (const g of puzzle) {
      if (solvedGroups.includes(g)) continue;
      const overlap = guess.filter(n => g.numbers.includes(n)).length;
      if (overlap === 3) { oneAway = true; break; }
    }

    // Shake
    const tileEls = document.querySelectorAll('.tile.selected');
    tileEls.forEach(el => el.classList.add('shake'));
    setTimeout(() => document.querySelectorAll('.tile.shake').forEach(el => el.classList.remove('shake')), 500);

    if (oneAway) showToast('One away!');

    renderMistakes();

    if (mistakes >= MAX_MISTAKES) {
      gameOver = true; won = false;
      setTimeout(() => {
        for (const g of puzzle) {
          if (!solvedGroups.includes(g)) {
            solvedGroups.push(g);
            solveOrder.push('missed');
          }
        }
        tiles = []; selected.clear();
        saveGameState();
        recordGame(false, mistakes);
        render();
        setTimeout(() => showEndState(), 400);
      }, 800);
    }
  }
}

/* ══════════════════════════════════════════════════════════
   TOAST
   ══════════════════════════════════════════════════════════ */
let toastTimeout = null;
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimeout);
  toastTimeout = setTimeout(() => el.classList.remove('show'), 1500);
}

/* ══════════════════════════════════════════════════════════
   END STATE
   ══════════════════════════════════════════════════════════ */
function showEndState() {
  const el = document.getElementById('endState');
  document.getElementById('endTitle').textContent = won ? 'Excellent!' : 'Better luck tomorrow';

  const emojiMap = { yellow: '🟨', green: '🟩', blue: '🟦', purple: '🟪', missed: '⬛' };
  const emojiStr = solveOrder.map(c => emojiMap[c] || '⬛').join('');
  document.getElementById('endEmojis').textContent = emojiStr + (mistakes > 0 ? '  ' + '❌'.repeat(mistakes) : '');

  el.classList.add('show');
  startCountdown();
}

function startCountdown() {
  function update() {
    const midnight = new Date(); midnight.setUTCHours(24,0,0,0);
    const diff = midnight.getTime() - Date.now();
    if (diff <= 0) { document.getElementById('countdown').textContent = 'New puzzle available now!'; return; }
    const h = Math.floor(diff/3600000);
    const m = Math.floor((diff%3600000)/60000);
    const s = Math.floor((diff%60000)/1000);
    document.getElementById('countdown').textContent =
      'Next puzzle in '+String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  }
  update(); setInterval(update, 1000);
}

function copyResult() {
  const emojiMap = { yellow: '🟨', green: '🟩', blue: '🟦', purple: '🟪', missed: '⬛' };
  const emojiStr = solveOrder.map(c => emojiMap[c] || '⬛').join('');
  const mistakeStr = mistakes > 0 ? '\n' + '❌'.repeat(mistakes) : '';
  const text = 'FOUR #' + dayNumber + '\n' + emojiStr + mistakeStr + '\nfourpuzzle.com';
  const btn = document.getElementById('copyBtn');
  const finish = () => {
    btn.textContent = 'Copied!'; btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Share'; btn.classList.remove('copied'); }, 2000);
  };
  if (navigator.clipboard) navigator.clipboard.writeText(text).then(finish).catch(() => legacyCopy(text, finish));
  else legacyCopy(text, finish);
}

function legacyCopy(text, cb) {
  const ta = document.createElement('textarea');
  ta.value = text; ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0';
  document.body.appendChild(ta); ta.select();
  try { document.execCommand('copy'); } catch(e) {}
  document.body.removeChild(ta); cb();
}

/* ══════════════════════════════════════════════════════════
   STATS MODAL
   ══════════════════════════════════════════════════════════ */
function openStats() {
  const stats = loadStats();
  document.getElementById('statPlayed').textContent = stats.played;
  document.getElementById('statWin').textContent = stats.played ? Math.round(stats.wins / stats.played * 100) : 0;
  document.getElementById('statStreak').textContent = stats.streak;
  document.getElementById('statMax').textContent = stats.maxStreak;

  const chart = document.getElementById('distChart');
  chart.innerHTML = '';
  const maxVal = Math.max(...stats.dist, 1);
  for (let i = 0; i < 5; i++) {
    const val = stats.dist[i] || 0;
    const pct = Math.max(val / maxVal * 100, 8);
    const isCurrent = gameOver && won && mistakes === i;
    chart.innerHTML +=
      '<div class="dist-row">' +
        '<span class="dist-label">' + i + '</span>' +
        '<div class="dist-bar-wrap">' +
          '<div class="dist-bar' + (isCurrent ? ' highlight' : '') + '" style="width:' + pct + '%">' + val + '</div>' +
        '</div>' +
      '</div>';
  }
  document.getElementById('statsModal').classList.add('show');
}

function closeStats() {
  document.getElementById('statsModal').classList.remove('show');
}

document.getElementById('statsBtn').addEventListener('click', openStats);
document.getElementById('statsModal').addEventListener('click', function(e) {
  if (e.target === this) closeStats();
});

/* ══════════════════════════════════════════════════════════
   TUTORIAL
   ══════════════════════════════════════════════════════════ */
let tutorialStep = 0;
const TUTORIAL_STEPS = 4;

function openTutorial() {
  tutorialStep = 0;
  updateTutorial();
  document.getElementById('tutorialModal').classList.add('show');
}

function closeTutorial() {
  document.getElementById('tutorialModal').classList.remove('show');
  try { localStorage.setItem('four-tutorial-seen', '1'); } catch(e) {}
}

function tutorialNav(dir) {
  tutorialStep += dir;
  if (tutorialStep >= TUTORIAL_STEPS) { closeTutorial(); return; }
  if (tutorialStep < 0) tutorialStep = 0;
  updateTutorial();
}

function updateTutorial() {
  for (let i = 0; i < TUTORIAL_STEPS; i++) {
    document.getElementById('tutStep' + i).classList.toggle('active', i === tutorialStep);
  }
  document.getElementById('tutPrev').style.visibility = tutorialStep === 0 ? 'hidden' : 'visible';
  document.getElementById('tutNext').textContent = tutorialStep === TUTORIAL_STEPS - 1 ? 'Play' : 'Next';
}

document.getElementById('helpBtn').addEventListener('click', openTutorial);
document.getElementById('tutorialModal').addEventListener('click', function(e) {
  if (e.target === this) closeTutorial();
});

/* ══════════════════════════════════════════════════════════
   EXPLORER
   ══════════════════════════════════════════════════════════ */
function exploreNumber() {
  const inp = document.getElementById('explorerInput');
  const n = parseInt(inp.value, 10);
  if (isNaN(n) || n <= 0) return;
  const chain = buildChain(n);
  const parts = chain.map(s => {
    const isMagic = s.count === 4;
    const cls = isMagic ? 'magic' : 'num';
    return '<span class="'+cls+'">'+s.value+'</span> → <span class="'+cls+'">'+s.count+'</span>';
  });
  document.getElementById('explorerResult').innerHTML = parts.join(' → ');
}
document.getElementById('explorerInput').addEventListener('keydown', e => { if (e.key === 'Enter') exploreNumber(); });

/* ══════════════════════════════════════════════════════════
   INIT
   ══════════════════════════════════════════════════════════ */
function init() {
  dayNumber = getDayNumber();
  document.getElementById('dayNum').textContent = dayNumber;
  document.getElementById('dateLabel').textContent = todayStr();

  puzzle = generatePuzzle(dayNumber);

  const saved = loadGameState();
  if (saved) {
    mistakes = saved.mistakes || 0;
    gameOver = saved.gameOver || false;
    won = saved.won || false;
    solveOrder = saved.solveOrder || [];
    previousGuesses = saved.previousGuesses || [];

    const solvedIndices = saved.solvedGroupIndices || [];
    solvedGroups = solvedIndices.map(i => puzzle[i]).filter(Boolean);

    const solvedNums = new Set(solvedGroups.flatMap(g => g.numbers));
    tiles = puzzle.flatMap(g => g.numbers).filter(n => !solvedNums.has(n));

    // Consistent shuffle for reload
    const tileRng = mulberry32(dayNumber * 31337 + 42);
    tiles = seededShuffle(tiles, tileRng);

    render();
    if (gameOver) showEndState();
  } else {
    solvedGroups = [];
    solveOrder = [];
    mistakes = 0;
    gameOver = false;
    won = false;
    previousGuesses = [];

    const rng = mulberry32(dayNumber * 31337 + 42);
    tiles = seededShuffle(puzzle.flatMap(g => g.numbers), rng);

    render();
  }

  // First-visit tutorial
  if (!localStorage.getItem('four-tutorial-seen')) {
    openTutorial();
  }
}

init();
</script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Daily Four · Four is the Magic Number</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet" />
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg:       #0c1d3a;
  --surface:  #112247;
  --border:   #1e3a6e;
  --text:     #e8f3fd;
  --muted:    #7ba3cc;
  --dim:      #3a5f8a;
  --accent:   #a8d4f5;
  --green:    #6dd5a8;
  --yellow:   #f5d76e;
  --red:      #e07878;
  --glow:     0 0 18px rgba(168,212,245,0.28), 0 0 50px rgba(168,212,245,0.1);
}

html { scroll-behavior: smooth; }

html, body {
  min-height: 100vh;
  background-color: var(--bg);
  background-image:
    linear-gradient(rgba(168,212,245,0.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(168,212,245,0.045) 1px, transparent 1px);
  background-size: 44px 44px;
  color: var(--text);
  font-family: 'JetBrains Mono', monospace;
  overflow-x: hidden;
}

/* ghost 4 */
.ghost-four {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}
.ghost-four span {
  font-family: 'Cinzel', serif;
  font-size: clamp(60vw, 80vw, 90vh);
  font-weight: 900;
  color: transparent;
  -webkit-text-stroke: 1px rgba(168,212,245,0.07);
  user-select: none;
  line-height: 1;
  animation: breathe 8s ease-in-out infinite;
}
@keyframes breathe {
  0%, 100% { opacity: 0.7; transform: scale(1); }
  50%       { opacity: 1;   transform: scale(1.015); }
}

/* sections */
.section {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2.5rem 1.5rem 3rem;
}
.how-section {
  background: rgba(8, 16, 34, 0.6);
  border-top: 1px solid var(--border);
  justify-content: flex-start;
  padding-top: 4rem;
}

/* content wrapper */
.wrap {
  width: 100%;
  max-width: 680px;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

/* header */
header { text-align: center; }
.eyebrow {
  font-size: 0.62rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--dim);
  margin-bottom: 1rem;
}
h1 {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.8rem, 5vw, 2.8rem);
  font-weight: 700;
  letter-spacing: 0.05em;
  color: var(--text);
  line-height: 1.15;
  text-shadow: var(--glow);
  margin-bottom: 0.6rem;
}
h1 em { font-style: normal; color: var(--accent); }
.date-label {
  font-size: 0.65rem;
  color: var(--muted);
  letter-spacing: 0.2em;
  text-transform: uppercase;
}
.rule { border: none; border-top: 1px solid var(--border); }

/* puzzle */
#puzzleArea { display: flex; flex-direction: column; gap: 0.75rem; }
.puzzle-row { display: flex; align-items: center; flex-wrap: nowrap; position: relative; }
.cells-wrap { display: flex; align-items: center; flex: 1; min-width: 0; }
.arrow { color: var(--dim); font-size: 0.75rem; padding: 0 0.25rem; flex-shrink: 0; user-select: none; }
.cell {
  width: 56px;
  height: 56px;
  flex-shrink: 0;
  border: 1px solid var(--border);
  background: var(--surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text);
  position: relative;
  transition: border-color 0.2s, background 0.2s;
}
.cell.blank { background: rgba(168,212,245,0.05); border-color: var(--dim); }
.cell.blank:focus-within {
  border-color: var(--accent);
  box-shadow: 0 0 0 1px var(--dim), inset 0 0 12px rgba(168,212,245,0.07);
}
.cell input {
  width: 100%;
  height: 100%;
  background: transparent;
  border: none;
  outline: none;
  text-align: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text);
  caret-color: var(--accent);
  -moz-appearance: textfield;
  padding: 0;
}
.cell input::-webkit-inner-spin-button,
.cell input::-webkit-outer-spin-button { -webkit-appearance: none; }
.cell.correct { background: rgba(109,213,168,0.18); border-color: var(--green); color: var(--green); }
.cell.correct input { color: var(--green); }
.cell.revealed { background: rgba(224,120,120,0.12); border-color: var(--red); color: var(--muted); font-style: italic; }
.cell.revealed input { color: var(--muted); font-style: italic; }
.cell.wrong-flash { animation: cellShake 0.42s ease; }
.cell.do-flip { animation: cellFlip 0.42s ease forwards; }
@keyframes cellFlip {
  0%   { transform: scaleY(1);    background: var(--surface);              border-color: var(--border); }
  44%  { transform: scaleY(0.04); background: var(--surface);              border-color: var(--border); }
  56%  { transform: scaleY(0.04); background: rgba(109,213,168,0.18);      border-color: var(--green); }
  100% { transform: scaleY(1);    background: rgba(109,213,168,0.18);      border-color: var(--green); }
}
@keyframes cellShake {
  0%, 100% { transform: translateX(0); }
  15%      { transform: translateX(-6px); }
  35%      { transform: translateX(6px); }
  55%      { transform: translateX(-4px); }
  75%      { transform: translateX(4px); }
  90%      { transform: translateX(-2px); }
}

/* row buttons */
.row-actions { display: flex; align-items: center; gap: 0.5rem; margin-left: 0.75rem; flex-shrink: 0; }
.btn {
  padding: 0.5rem 0.9rem;
  background: transparent;
  font-family: 'Cinzel', serif;
  font-size: 0.62rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.btn-check { border: 1px solid var(--dim); color: var(--accent); }
.btn-check:hover { background: rgba(168,212,245,0.08); border-color: var(--accent); color: var(--text); }
.btn-check:disabled { opacity: 0.3; cursor: default; pointer-events: none; }
.btn-reveal { border: 1px solid var(--border); color: var(--muted); }
.btn-reveal:hover { background: rgba(224,120,120,0.1); border-color: var(--red); color: var(--red); }
.btn-reveal:disabled { opacity: 0.3; cursor: default; pointer-events: none; }
.row-check { color: var(--green); font-size: 1rem; flex-shrink: 0; }

/* end state */
#endState {
  display: none;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
  text-align: center;
  padding: 1.75rem 1.5rem;
  border: 1px solid var(--border);
  background: var(--surface);
  position: relative;
  overflow: hidden;
}
#endState::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(168,212,245,0.04) 0%, transparent 60%);
  pointer-events: none;
}
#endState.show { display: flex; }
.end-score {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.4rem, 4vw, 2rem);
  color: var(--accent);
  text-shadow: var(--glow);
  font-weight: 700;
}
.end-emojis { font-size: 1.6rem; letter-spacing: 0.12em; line-height: 1.5; }
.end-buttons { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; }
.copy-btn {
  padding: 0.65rem 1.8rem;
  background: transparent;
  border: 1px solid var(--dim);
  color: var(--accent);
  font-family: 'Cinzel', serif;
  font-size: 0.72rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, border-color 0.2s;
}
.copy-btn:hover { background: rgba(168,212,245,0.08); border-color: var(--accent); color: var(--text); }
.copy-btn.copied { border-color: var(--green); color: var(--green); }
.countdown { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; min-height: 1.2em; }

/* scroll hint */
.scroll-hint { text-align: center; }
.scroll-hint a {
  font-size: 0.6rem;
  color: var(--dim);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-decoration: none;
  transition: color 0.2s;
}
.scroll-hint a:hover { color: var(--muted); }

/* how section */
.section-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.2rem, 3vw, 1.8rem);
  font-weight: 700;
  letter-spacing: 0.05em;
  color: var(--text);
  text-shadow: var(--glow);
  text-align: center;
  margin-bottom: 0.5rem;
}
.section-sub { font-size: 0.75rem; color: var(--muted); line-height: 1.8; letter-spacing: 0.03em; text-align: center; }

/* explorer */
.explorer { display: flex; flex-direction: column; gap: 0.75rem; }
.explorer-label { font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--dim); }
.explorer-row {
  display: flex;
  border: 1px solid var(--border);
  background: var(--surface);
  transition: border-color 0.25s;
}
.explorer-row:focus-within { border-color: var(--dim); }
.explorer-input {
  flex: 1;
  min-width: 0;
  background: transparent;
  border: none;
  outline: none;
  padding: 0.75rem 1rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 1rem;
  color: var(--text);
  caret-color: var(--accent);
  -moz-appearance: textfield;
}
.explorer-input::-webkit-inner-spin-button,
.explorer-input::-webkit-outer-spin-button { -webkit-appearance: none; }
.explorer-input::placeholder { color: var(--dim); font-style: italic; }
.explorer-go {
  padding: 0.75rem 1.1rem;
  background: transparent;
  border: none;
  border-left: 1px solid var(--border);
  color: var(--accent);
  font-family: 'Cinzel', serif;
  font-size: 0.6rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s;
  white-space: nowrap;
  flex-shrink: 0;
}
.explorer-go:hover { background: rgba(168,212,245,0.08); }
.explorer-result { font-size: 0.78rem; color: var(--muted); min-height: 1.6em; line-height: 2; font-style: italic; }
.explorer-result .num { color: var(--text); font-style: normal; font-weight: 700; }
.explorer-result .magic { color: var(--accent); font-style: normal; font-weight: 700; font-size: 1.05em; text-shadow: var(--glow); }

/* explanation */
.explain-block {
  border: 1px solid var(--border);
  background: var(--surface);
  padding: 1.25rem 1.5rem;
  font-size: 0.8rem;
  color: var(--muted);
  line-height: 1.9;
  letter-spacing: 0.02em;
  position: relative;
  overflow: hidden;
}
.explain-block::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(168,212,245,0.03) 0%, transparent 60%);
  pointer-events: none;
}
.explain-block strong { color: var(--text); font-weight: 700; }
.explain-block em { color: var(--accent); font-style: normal; }

/* footer */
footer {
  text-align: center;
  font-size: 0.6rem;
  color: var(--dim);
  letter-spacing: 0.15em;
  line-height: 2;
  padding-top: 1rem;
  border-top: 1px solid var(--border);
}
footer a { color: var(--dim); text-decoration: none; transition: color 0.2s; }
footer a:hover { color: var(--muted); }

/* responsive */
@media (max-width: 600px) {
  .cell { width: 48px; height: 48px; font-size: 0.85rem; }
  .cell input { font-size: 0.85rem; }
  .arrow { padding: 0 0.15rem; font-size: 0.65rem; }
  .row-actions { margin-left: 0.4rem; }
  .btn { padding: 0.4rem 0.6rem; font-size: 0.58rem; }
}
@media (max-width: 480px) {
  .puzzle-row { flex-wrap: wrap; }
  .cells-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .row-actions { width: 100%; margin-left: 0; justify-content: flex-end; }
}
</style>
</head>
<body>

<div class="ghost-four" aria-hidden="true"><span>4</span></div>

<!-- ── PUZZLE ── -->
<section class="section">
  <div class="wrap">
    <header>
      <p class="eyebrow">FOUR &middot; #<span id="dayNum">&mdash;</span></p>
      <h1>Daily <em>Four</em></h1>
      <p class="date-label" id="dateLabel">&mdash;</p>
    </header>
    <hr class="rule" />
    <div id="puzzleArea"></div>
    <div id="endState">
      <div class="end-score" id="endScore">Score: &mdash;/5</div>
      <div class="end-emojis" id="endEmojis"></div>
      <div class="end-buttons">
        <button class="copy-btn" id="copyBtn" onclick="copyResult()">Copy Result</button>
      </div>
      <div class="countdown" id="countdown"></div>
    </div>
    <hr class="rule" />
    <div class="scroll-hint">
      <a href="#howSection">how does this work? &darr;</a>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ── -->
<section class="section how-section" id="howSection">
  <div class="wrap">
    <header>
      <h2 class="section-title">How does this work?</h2>
      <p class="section-sub">Every number eventually leads to 4. Try one and see.</p>
    </header>
    <hr class="rule" />
    <div class="explorer">
      <span class="explorer-label">Enter any number</span>
      <div class="explorer-row">
        <input class="explorer-input" type="number" id="explorerInput" placeholder="try 23, 100, 999&hellip;" min="1" inputmode="numeric" pattern="[0-9]*" />
        <button class="explorer-go" onclick="exploreNumber()">Go &rarr;</button>
      </div>
      <div class="explorer-result" id="explorerResult">&mdash;</div>
    </div>
    <div class="explain-block">
      Count the letters in any number&rsquo;s name. <strong>Five</strong> has <em>4</em> letters &mdash; done.
      <strong>Seven</strong> has <em>5</em> letters &rarr; <strong>five</strong> has <em>4</em>.
      Keep going and you always land on <em>four</em>, because <strong>four</strong> is the only number
      whose letter count equals itself. It is the fixed point. The magic number.
    </div>
    <hr class="rule" />
    <footer>
      <a href="/magic">explore more &rarr;</a><br>
      christopherjharper.com
    </footer>
  </div>
</section>

<script>
/* ── chain logic ── */
const ONEs = ['zero','one','two','three','four','five','six','seven','eight','nine','ten','eleven','twelve','thirteen','fourteen','fifteen','sixteen','seventeen','eighteen','nineteen'];
const TENs = ['','','twenty','thirty','forty','fifty','sixty','seventy','eighty','ninety'];

function toWords(n) {
  if (n < 0)    return 'negative ' + toWords(-n);
  if (n < 20)   return ONEs[n];
  if (n < 100)  { const t = TENs[Math.floor(n/10)], o = n%10; return o ? t+'-'+ONEs[o] : t; }
  if (n < 1000) { const h = Math.floor(n/100), r = n%100; return ONEs[h]+' hundred'+(r ? ' '+toWords(r) : ''); }
  if (n < 10000){ const k = Math.floor(n/1000), r = n%1000; return toWords(k)+' thousand'+(r ? ' '+toWords(r) : ''); }
  return n.toString();
}

function letterCount(n) {
  return toWords(Math.abs(n)).replace(/[^a-z]/gi,'').length;
}

function buildChain(n) {
  const steps = [], seen = new Set();
  let cur = n;
  while (true) {
    if (seen.has(cur) || steps.length > 30) break;
    seen.add(cur);
    const cnt = letterCount(cur);
    steps.push({ value: cur, count: cnt });
    if (cnt === 4) break;
    cur = cnt;
  }
  return steps;
}

/* ── seeded prng ── */
function mulberry32(seed) {
  return function() {
    seed |= 0; seed = seed + 0x6D2B79F5 | 0;
    let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

const EPOCH = new Date('2025-01-01T00:00:00Z').getTime();
function getDayNumber() { return Math.floor((Date.now() - EPOCH) / 86400000); }

function todayStr() {
  const d = new Date();
  return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
}

// No position 0 in any blank pattern — guarantees one unique correct answer per row
// (pos 0 always visible anchors the deterministic left-to-right chain)
const BLANK_PATTERNS = [[3,4],[2,4],[1,4],[2,3],[1,3]];

function generatePuzzle(dayNumber) {
  const rng = mulberry32(dayNumber * 1000003 + 7919);
  // Store each candidate with its chain root so we can prevent
  // two rows from being windows of the same underlying chain.
  const candidates = [];
  for (let n = 10; n <= 9999; n++) {
    const chain = buildChain(n);
    if (chain.length < 6) continue;
    const usable = chain.filter(s => s.value !== 4);
    for (let start = 0; start <= usable.length - 5; start++) {
      const segment = usable.slice(start, start + 5).map(s => s.value);
      if (new Set(segment).size !== 5) continue;
      if (segment.includes(4)) continue;
      if (segment.some(v => v <= 0)) continue;
      if (Math.max(...segment) > 9999) continue;
      candidates.push({ seg: segment, root: n });
    }
  }
  const rows = [];
  const usedRoots = new Set();   // no two rows from the same chain
  const usedValues = new Set();  // no value appears in more than one row (whole segment)
  let attempts = 0;
  while (rows.length < 5 && attempts < 100000) {
    attempts++;
    const idx = Math.floor(rng() * candidates.length);
    const { seg, root } = candidates[idx];
    if (usedRoots.has(root)) continue;
    // Only block reuse of large values (> 9) — small convergent tail values
    // (3, 5, 6, 7, 8, 9 etc.) are intrinsic to the math and will overlap;
    // blocking them makes the candidate pool too thin.
    if (seg.filter(v => v > 9).some(v => usedValues.has(v))) continue;
    const blankPattern = BLANK_PATTERNS[rows.length];
    rows.push({ cells: seg, blanks: blankPattern, difficulty: rows.length + 1 });
    usedRoots.add(root);
    seg.filter(v => v > 9).forEach(v => usedValues.add(v));
  }
  return rows;
}


/* ── storage ── */
const STORAGE_KEY = () => 'four-puzzle-' + todayStr();
function loadState() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY())); } catch(e) { return null; } }
function saveState(s) { try { localStorage.setItem(STORAGE_KEY(), JSON.stringify(s)); } catch(e) {} }

/* ── game state ── */
let puzzle = [], rowStates = [], dayNumber = 0;

/* ── render ── */
function renderPuzzle() {
  const area = document.getElementById('puzzleArea');
  area.innerHTML = '';
  puzzle.forEach((row, ri) => {
    const rs = rowStates[ri];
    const rowEl = document.createElement('div');
    rowEl.className = 'puzzle-row'; rowEl.id = 'row-'+ri;
    const cellsWrap = document.createElement('div');
    cellsWrap.className = 'cells-wrap';
    row.cells.forEach((val, ci) => {
      if (ci > 0) {
        const arr = document.createElement('span');
        arr.className = 'arrow'; arr.textContent = '→';
        cellsWrap.appendChild(arr);
      }
      const cellEl = document.createElement('div');
      cellEl.className = 'cell'; cellEl.id = 'cell-'+ri+'-'+ci;
      const isBlank = row.blanks.includes(ci);
      if (rs.state === 'correct') {
        cellEl.classList.add('correct');
        cellEl.textContent = val;
      } else if (rs.state === 'revealed' && isBlank) {
        cellEl.classList.add('revealed');
        cellEl.textContent = val;
      } else if (!isBlank) {
        cellEl.textContent = val;
      } else {
        cellEl.classList.add('blank');
        const inp = document.createElement('input');
        inp.type = 'number'; inp.min = '1'; inp.max = '9999';
        inp.inputMode = 'numeric'; inp.pattern = '[0-9]*';
        inp.autocomplete = 'off'; inp.id = 'inp-'+ri+'-'+ci;
        inp.setAttribute('aria-label', 'Row '+(ri+1)+' blank '+(ci+1));
        if (rs.inputs && rs.inputs[ci] !== undefined) inp.value = rs.inputs[ci];
        inp.addEventListener('blur', () => { if (inp.value) inp.value = parseInt(inp.value,10)||''; });
        inp.addEventListener('keydown', e => {
          if (e.key === 'Enter') {
            const bp = row.blanks; const myPos = bp.indexOf(ci);
            if (myPos === bp.length - 1) checkRow(ri);
            else { const ni = document.getElementById('inp-'+ri+'-'+bp[myPos+1]); if(ni) ni.focus(); }
          }
        });
        inp.addEventListener('input', () => {
          if (!rowStates[ri].inputs) rowStates[ri].inputs = {};
          rowStates[ri].inputs[ci] = inp.value;
        });
        cellEl.appendChild(inp);
      }
      cellsWrap.appendChild(cellEl);
    });
    rowEl.appendChild(cellsWrap);
    const actions = document.createElement('div');
    actions.className = 'row-actions';
    if (rs.state === 'correct') {
      const ck = document.createElement('span'); ck.className = 'row-check'; ck.textContent = '✓';
      actions.appendChild(ck);
    } else if (rs.state === 'revealed') {
      const lb = document.createElement('span');
      lb.style.cssText = 'font-size:0.6rem;color:var(--muted);letter-spacing:0.1em';
      lb.textContent = 'revealed'; actions.appendChild(lb);
    } else {
      const cb = document.createElement('button'); cb.className = 'btn btn-check'; cb.textContent = 'Check';
      cb.onclick = () => checkRow(ri); actions.appendChild(cb);
      if (rs.attempts > 0) {
        const rb = document.createElement('button'); rb.className = 'btn btn-reveal'; rb.textContent = 'Reveal';
        rb.onclick = () => revealRow(ri); actions.appendChild(rb);
      }
    }
    rowEl.appendChild(actions);
    area.appendChild(rowEl);
  });
  for (let ri = 0; ri < puzzle.length; ri++) {
    const rs = rowStates[ri];
    if (rs.state === 'pending' || rs.state === 'incorrect') {
      const fb = puzzle[ri].blanks[0];
      const inp = document.getElementById('inp-'+ri+'-'+fb);
      if (inp) setTimeout(() => inp.focus(), 100);
      break;
    }
  }
}

/* ── check row ── */
function checkRow(ri) {
  const row = puzzle[ri]; const rs = rowStates[ri];
  if (rs.state !== 'pending' && rs.state !== 'incorrect') return;
  const guesses = {};
  for (const ci of row.blanks) {
    const inp = document.getElementById('inp-'+ri+'-'+ci);
    const v = inp ? parseInt(inp.value, 10) : NaN;
    if (isNaN(v) || v < 1) { if(inp) inp.focus(); return; }
    guesses[ci] = v;
  }
  // Unique correct answer: compare directly to the actual segment values
  let allCorrect = true;
  const wrongIndices = [];
  for (const ci of row.blanks) {
    if (guesses[ci] !== row.cells[ci]) { allCorrect = false; wrongIndices.push(ci); }
  }
  if (allCorrect) {
    rs.state = 'correct'; rs.attempts++;
    const delay = 80;
    const cellEls = row.cells.map((_,ci) => document.getElementById('cell-'+ri+'-'+ci)).filter(Boolean);
    cellEls.forEach((el,i) => setTimeout(() => el.classList.add('do-flip'), i*delay));
    persistState();
    setTimeout(() => { renderPuzzle(); checkCompletion(); }, cellEls.length*delay + 440);
  } else {
    rs.state = 'incorrect'; rs.attempts++;
    for (const ci of wrongIndices) {
      const el = document.getElementById('cell-'+ri+'-'+ci);
      if (!el) continue;
      el.classList.remove('wrong-flash'); void el.offsetWidth; el.classList.add('wrong-flash');
      setTimeout(() => el.classList.remove('wrong-flash'), 500);
    }
    persistState();
    setTimeout(() => renderPuzzle(), 0);
  }
}

/* ── reveal row ── */
function revealRow(ri) {
  rowStates[ri].state = 'revealed';
  persistState(); renderPuzzle(); checkCompletion();
}

/* ── completion ── */
function checkCompletion() {
  if (!rowStates.every(rs => rs.state === 'correct' || rs.state === 'revealed')) return;
  const s = buildStorageState(); s.completed = true; saveState(s); showEndState(s);
}

function buildStorageState() {
  return {
    date: todayStr(),
    rowResults: rowStates.map(rs => {
      if (rs.state === 'correct' && rs.attempts === 1) return 'solved';
      if (rs.state === 'correct' && rs.attempts > 1) return 'solved-mistakes';
      if (rs.state === 'revealed') return 'failed';
      return 'pending';
    }),
    rowStateData: rowStates.map(rs => ({ state: rs.state, attempts: rs.attempts })),
    completed: false,
    score: rowStates.filter(rs => rs.state === 'correct').length,
  };
}

function persistState() { const s = buildStorageState(); saveState(s); }

/* ── end state ── */
function showEndState(savedState) {
  const results = savedState.rowResults || [];
  const score = results.filter(r => r === 'solved' || r === 'solved-mistakes').length;
  document.getElementById('endScore').textContent = 'Score: '+score+'/5';
  const emojis = results.map(r => r==='solved' ? '🟦' : r==='solved-mistakes' ? '🟨' : '⬛');
  document.getElementById('endEmojis').textContent = emojis.join('');
  document.getElementById('endState').classList.add('show');
  startCountdown();
}

function startCountdown() {
  function update() {
    const midnight = new Date(); midnight.setUTCHours(24,0,0,0);
    const diff = midnight.getTime() - Date.now();
    if (diff <= 0) { document.getElementById('countdown').textContent = 'New puzzle available now!'; return; }
    const h = Math.floor(diff/3600000);
    const m = Math.floor((diff%3600000)/60000);
    const s = Math.floor((diff%60000)/1000);
    document.getElementById('countdown').textContent = 'Next puzzle in '+String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  }
  update(); setInterval(update, 1000);
}

function copyResult() {
  const results = (loadState()||{}).rowResults||[];
  const score = results.filter(r => r==='solved'||r==='solved-mistakes').length;
  const emojis = results.map(r => r==='solved' ? '🟦' : r==='solved-mistakes' ? '🟨' : '⬛').join('');
  const text = 'FOUR #'+dayNumber+'\n'+emojis+'\n'+score+'/5 · fourpuzzle.com';
  const btn = document.getElementById('copyBtn');
  const finish = () => {
    btn.textContent = 'Copied!'; btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy Result'; btn.classList.remove('copied'); }, 2000);
  };
  if (navigator.clipboard) navigator.clipboard.writeText(text).then(finish).catch(() => legacyCopy(text,finish));
  else legacyCopy(text, finish);
}

function legacyCopy(text, cb) {
  const ta = document.createElement('textarea');
  ta.value = text; ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0';
  document.body.appendChild(ta); ta.select();
  try { document.execCommand('copy'); } catch(e) {}
  document.body.removeChild(ta); cb();
}

/* ── explorer ── */
function exploreNumber() {
  const inp = document.getElementById('explorerInput');
  const n = parseInt(inp.value, 10);
  if (isNaN(n) || n <= 0) return;
  const chain = buildChain(n);
  const parts = chain.map(s => {
    const isMagic = s.count === 4;
    const cls = isMagic ? 'magic' : 'num';
    return '<span class="'+cls+'">'+s.value+'</span> &rarr; <span class="'+cls+'">'+s.count+'</span>';
  });
  document.getElementById('explorerResult').innerHTML = parts.join(' &rarr; ');
}
document.getElementById('explorerInput').addEventListener('keydown', e => { if (e.key === 'Enter') exploreNumber(); });

/* ── init ── */
function init() {
  dayNumber = getDayNumber();
  document.getElementById('dayNum').textContent = dayNumber;
  document.getElementById('dateLabel').textContent = todayStr();
  puzzle = generatePuzzle(dayNumber);
  const saved = loadState();
  if (saved && saved.completed) {
    rowStates = saved.rowStateData
      ? saved.rowStateData.map(d => ({ state: d.state, attempts: d.attempts, inputs: {} }))
      : puzzle.map((_,ri) => ({ state: (saved.rowResults[ri]==='failed'||saved.rowResults[ri]==='pending') ? 'revealed' : 'correct', attempts: 1, inputs: {} }));
    renderPuzzle(); showEndState(saved);
  } else if (saved && !saved.completed && saved.rowStateData) {
    rowStates = saved.rowStateData.map(d => ({ state: d.state, attempts: d.attempts, inputs: {} }));
    renderPuzzle();
  } else {
    rowStates = puzzle.map(() => ({ state: 'pending', attempts: 0, inputs: {} }));
    renderPuzzle();
  }
}

init();
</script>
</body>
</html>
