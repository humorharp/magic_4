<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Daily Four · Four is the Magic Number</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  :root {
    --bg:      #06060e;
    --surface: #0b0b18;
    --border:  #1c1c30;
    --gold:    #c9a84c;
    --gold-hi: #f0cc70;
    --gold-lo: #7a6030;
    --text:    #ddd4bc;
    --muted:   #6a6250;
    --dim:     #2e2c24;
    --green:   #4ecb8d;
    --yellow:  #c9a84c;
    --red:     #e06060;
    --glow: 0 0 18px rgba(201,168,76,0.35), 0 0 60px rgba(201,168,76,0.12);
  }
  html, body {
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    display: flex; flex-direction: column; align-items: center;
    padding: 2rem 1.5rem 4rem;
    overflow-x: hidden;
  }
  .ghost-four {
    position: fixed; inset: 0;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none; z-index: 0; overflow: hidden;
  }
  .ghost-four span {
    font-family: 'Cinzel', serif;
    font-size: clamp(60vw, 80vw, 90vh); font-weight: 900;
    color: transparent;
    -webkit-text-stroke: 1px rgba(201,168,76,0.045);
    user-select: none; line-height: 1;
    animation: breathe 8s ease-in-out infinite;
  }
  @keyframes breathe {
    0%,100% { opacity: 0.6; transform: scale(1); }
    50%     { opacity: 1;   transform: scale(1.015); }
  }
  body::after {
    content: ''; position: fixed; inset: 0;
    background: repeating-linear-gradient(to bottom,
      transparent 0px, transparent 3px, rgba(0,0,0,0.08) 3px, rgba(0,0,0,0.08)
 4px);
    pointer-events: none; z-index: 100;
  }
  body::before {
    content: ''; position: fixed; inset: -50%; width: 200%; height: 200%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xml
ns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.4; pointer-events: none; z-index: 0;
  }
  .wrap {
    position: relative; z-index: 1;
    width: 100%; max-width: 680px;
    display: flex; flex-direction: column; gap: 1.5rem;
    margin-top: auto; margin-bottom: auto;
  }
  header { text-align: center; }
  .eyebrow {
    font-size: 0.62rem; letter-spacing: 0.4em;
    text-transform: uppercase; color: var(--gold-lo); margin-bottom: 1rem;
  }
  h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 700;
    letter-spacing: 0.05em; color: var(--text); line-height: 1.15;
    text-shadow: var(--glow); margin-bottom: 0.6rem;
  }
  h1 em { font-style: normal; color: var(--gold); }
  .date-label {
    font-size: 0.65rem; color: var(--muted);
    letter-spacing: 0.2em; text-transform: uppercase;
  }
  .rule { border: none; border-top: 1px solid var(--border); margin: 0; }
  #puzzleArea { display: flex; flex-direction: column; gap: 0.75rem; }
  .puzzle-row { display: flex; align-items: center; gap: 0; flex-wrap: nowrap;
 position: relative; }
  .cells-wrap { display: flex; align-items: center; gap: 0; flex: 1; min-width
: 0; }
  .arrow { color: var(--dim); font-size: 0.75rem; padding: 0 0.25rem; flex-shr
ink: 0; user-select: none; }
  .cell {
    width: 56px; height: 56px; flex-shrink: 0;
    border: 1px solid var(--border); background: var(--surface);
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95rem; font-weight: 700; color: var(--text);
    position: relative; transition: border-color 0.2s, background 0.2s;
  }
  .cell.blank { background: rgba(255,255,255,0.04); border-color: var(--gold-l
o); }
  .cell.blank:focus-within {
    border-color: var(--gold);
    box-shadow: 0 0 0 1px var(--gold-lo), inset 0 0 12px rgba(201,168,76,0.06)
;
  }
  .cell input {
    width: 100%; height: 100%;
    background: transparent; border: none; outline: none;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95rem; font-weight: 700; color: var(--text);
    caret-color: var(--gold);
    -moz-appearance: textfield; padding: 0;
    touch-action: manipulation;
  }
  .cell input::-webkit-inner-spin-button,
  .cell input::-webkit-outer-spin-button { -webkit-appearance: none; }
  .cell.correct { background: rgba(78,203,141,0.22); border-color: var(--green
); color: var(--green); }
  .cell.correct input { color: var(--green); }
  .cell.wrong-flash { animation: cellShake 0.42s ease; }
  .cell.revealed { background: rgba(224,96,96,0.10); border-color: var(--red);
 color: var(--muted); font-style: italic; }
  .cell.revealed input { color: var(--muted); font-style: italic; }
  .cell.do-flip { animation: cellFlip 0.42s ease forwards; }
  @keyframes cellFlip {
    0%   { transform: scaleY(1); background: var(--surface); border-color: var
(--border); }
    44%  { transform: scaleY(0.04); background: var(--surface); border-color: 
var(--border); }
    56%  { transform: scaleY(0.04); background: rgba(78,203,141,0.22); border-
color: var(--green); }
    100% { transform: scaleY(1); background: rgba(78,203,141,0.22); border-col
or: var(--green); }
  }
  @keyframes cellShake {
    0%,100% { transform: translateX(0); }
    15%     { transform: translateX(-6px); }
    35%     { transform: translateX(6px); }
    55%     { transform: translateX(-4px); }
    75%     { transform: translateX(4px); }
    90%     { transform: translateX(-2px); }
  }
  .row-actions { display: flex; align-items: center; gap: 0.5rem; margin-left:
 0.75rem; flex-shrink: 0; }
  .btn {
    padding: 0.5rem 0.9rem; background: transparent;
    font-family: 'Cinzel', serif; font-size: 0.62rem; letter-spacing: 0.2em;
    text-transform: uppercase; cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s; white-space: n
owrap;
  }
  .btn-check { border: 1px solid var(--gold-lo); color: var(--gold); }
  .btn-check:hover { background: rgba(201,168,76,0.08); border-color: var(--go
ld); color: var(--gold-hi); }
  .btn-check:disabled { opacity: 0.3; cursor: default; pointer-events: none; }
  .btn-reveal { border: 1px solid var(--border); color: var(--muted); }
  .btn-reveal:hover { background: rgba(224,96,96,0.08); border-color: var(--re
d); color: var(--red); }
  .btn-reveal:disabled { opacity: 0.3; cursor: default; pointer-events: none; 
}
  .row-check { color: var(--green); font-size: 1rem; flex-shrink: 0; }
  #endState {
    display: none; flex-direction: column; align-items: center; gap: 1.25rem;
    text-align: center; padding: 1.75rem 1.5rem;
    border: 1px solid var(--border); background: var(--surface);
    position: relative; overflow: hidden;
  }
  #endState::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(201,168,76,0.04) 0%, transparent 
60%);
    pointer-events: none;
  }
  #endState.show { display: flex; }
  .end-score {
    font-family: 'Cinzel', serif; font-size: clamp(1.4rem, 4vw, 2rem);
    color: var(--gold); text-shadow: var(--glow); font-weight: 700;
  }
  .end-emojis { font-size: 1.6rem; letter-spacing: 0.12em; line-height: 1.5; }
  .end-buttons { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content
: center; }
  .copy-btn {
    padding: 0.65rem 1.8rem; background: transparent;
    border: 1px solid var(--gold-lo); color: var(--gold);
    font-family: 'Cinzel', serif; font-size: 0.72rem; letter-spacing: 0.25em;
    text-transform: uppercase; cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .copy-btn:hover { background: rgba(201,168,76,0.08); border-color: var(--gol
d); color: var(--gold-hi); }
  .copy-btn.copied { border-color: var(--green); color: var(--green); }
  .countdown { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em;
 min-height: 1.2em; }
  footer { text-align: center; font-size: 0.6rem; color: var(--dim); letter-sp
acing: 0.15em; line-height: 2; }
  footer a { color: var(--dim); text-decoration: none; transition: color 0.2s;
 }
  footer a:hover { color: var(--muted); }
  #modal {
    position: fixed; inset: 0;
    background: rgba(6,6,14,0.88);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    z-index: 200;
    display: flex; align-items: center; justify-content: center;
    padding: 1rem; opacity: 0; transition: opacity 0.35s ease;
  }
  #modal.visible { opacity: 1; }
  .modal-card {
    background: var(--surface); border: 1px solid var(--border);
    max-width: 460px; width: 100%; padding: 2rem 2rem 1.75rem;
    display: flex; flex-direction: column; gap: 1.25rem;
    position: relative; z-index: 1;
  }
  .modal-step { display: none; flex-direction: column; gap: 1.25rem; }
  .modal-step.active { display: flex; }
  .modal-title { font-family: 'Cinzel', serif; font-size: 1.25rem; font-weight
: 700; color: var(--text); letter-spacing: 0.04em; }
  .modal-body { font-size: 0.82rem; color: var(--muted); line-height: 1.85; le
tter-spacing: 0.03em; }
  .mini-explorer { display: flex; flex-direction: column; gap: 0.75rem; }
  .mini-input-row {
    display: flex; border: 1px solid var(--border); background: var(--bg);
    transition: border-color 0.2s;
  }
  .mini-input-row:focus-within { border-color: var(--gold-lo); }
  .mini-input {
    flex: 1; min-width: 0; background: transparent; border: none; outline: non
e;
    padding: 0.65rem 0.9rem; font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem; color: var(--text); caret-color: var(--gold);
    -moz-appearance: textfield;
  }
  .mini-input::-webkit-inner-spin-button,
  .mini-input::-webkit-outer-spin-button { -webkit-appearance: none; }
  .mini-go {
    padding: 0.65rem 1rem; background: transparent; border: none;
    border-left: 1px solid var(--border); color: var(--gold);
    font-family: 'Cinzel', serif; font-size: 0.6rem; letter-spacing: 0.25em;
    text-transform: uppercase; cursor: pointer; transition: background 0.2s;
  }
  .mini-go:hover { background: rgba(201,168,76,0.08); }
  .mini-result { font-size: 0.75rem; color: var(--muted); min-height: 1.4em; l
ine-height: 1.8; font-style: italic; }
  .mini-result .num { color: var(--text); font-style: normal; font-weight: 700
; }
  .mini-result .magic { color: var(--gold); font-style: normal; font-weight: 7
00; }
  .answer-btns { display: flex; flex-direction: column; gap: 0.5rem; }
  .answer-btn {
    text-align: left; padding: 0.65rem 0.9rem;
    background: var(--bg); border: 1px solid var(--border);
    color: var(--text); cursor: pointer;
    font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; letter-spaci
ng: 0.02em;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }
  .answer-btn:hover { border-color: var(--gold-lo); background: rgba(201,168,7
6,0.05); }
  .answer-btn.wrong-flash { animation: btnRedFlash 0.5s ease; }
  .answer-btn.correct-flash { animation: btnGreenFlash 0.5s ease forwards; }
  @keyframes btnRedFlash {
    0%,100% { background: var(--bg); border-color: var(--border); }
    40%     { background: rgba(224,96,96,0.2); border-color: var(--red); color
: var(--red); }
  }
  @keyframes btnGreenFlash {
    0%   { background: var(--bg); border-color: var(--border); }
    100% { background: rgba(78,203,141,0.18); border-color: var(--green); colo
r: var(--green); }
  }
  .modal-continue {
    padding: 0.7rem 1.6rem; background: transparent;
    border: 1px solid var(--gold-lo); color: var(--gold);
    font-family: 'Cinzel', serif; font-size: 0.68rem; letter-spacing: 0.25em;
    text-transform: uppercase; cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s; align-self: fl
ex-start;
  }
  .modal-continue:hover { background: rgba(201,168,76,0.08); border-color: var
(--gold); color: var(--gold-hi); }
  .modal-continue:disabled { opacity: 0.35; cursor: default; pointer-events: n
one; }
  .correct-msg { font-size: 0.72rem; color: var(--green); letter-spacing: 0.05
em; display: none; }
  @media (max-width: 600px) {
    .cell { width: 48px; height: 48px; font-size: 0.85rem; }
    .cell input { font-size: 0.85rem; }
    .arrow { padding: 0 0.15rem; font-size: 0.65rem; }
    .row-actions { margin-left: 0.4rem; }
    .btn { padding: 0.4rem 0.6rem; font-size: 0.58rem; }
  }
  @media (max-width: 480px) {
    .puzzle-row { flex-wrap: wrap; }
    .cells-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .row-actions { width: 100%; margin-left: 0; justify-content: flex-end; }
    .modal-card { padding: 1.5rem 1.25rem; border-radius: 0; margin: 0; max-wi
dth: 100%; }
    #modal { padding: 0; align-items: flex-start; }
  }
</style>
</head>
<body>
<div class="ghost-four" aria-hidden="true"><span>4</span></div>

<div id="modal" role="dialog" aria-modal="true" aria-label="How to play">
  <div class="modal-card">
    <div class="modal-step active" id="modalStep1">
      <div class="modal-title">Before you play&hellip;</div>
      <div class="modal-body">Try entering a number below and pressing Go. Try
 a few. Notice anything?</div>
      <div class="mini-explorer">
        <div class="mini-input-row">
          <input class="mini-input" type="number" id="miniNumInput" placeholder="Enter any number&hellip;" min="1" max="999999" inputmode="numeric" pattern="[0-9]*" />
          <button class="mini-go" onclick="miniExplore()">Go &rarr;</button>
        </div>
        <div class="mini-result" id="miniResult">&mdash;</div>
      </div>
      <button class="modal-continue" id="miniContinue" onclick="goModalStep(2)" disabled>Continue &rarr;</button>
    </div>
    <div class="modal-step" id="modalStep2">
      <div class="modal-title">One question.</div>
      <div class="modal-body">Every number eventually leads to 4.<br>What make
s 4 different from all other numbers?</div>
      <div class="answer-btns">
        <button class="answer-btn" onclick="answerQuiz(this,false)">It&rsquo;s
 even</button>
        <button class="answer-btn" onclick="answerQuiz(this,false)">It&rsquo;s
 the smallest number with letters</button>
        <button class="answer-btn" onclick="answerQuiz(this,true)">It&rsquo;s 
the only number whose letter count equals itself</button>
        <button class="answer-btn" onclick="answerQuiz(this,false)">It sounds 
like &ldquo;for&rdquo;</button>
      </div>
      <div class="correct-msg" id="correctMsg">That&rsquo;s it. &check;</div>
      <button class="modal-continue" id="playBtn" onclick="dismissModal()" dis
abled>Play &rarr;</button>
    </div>
  </div>
</div>

<div class="wrap" id="mainWrap">
  <header>
    <p class="eyebrow">FOUR &middot; #<span id="dayNum">&mdash;</span></p>
    <h1>Daily <em>Four</em></h1>
    <p class="date-label" id="dateLabel">&mdash;</p>
  </header>
  <hr class="rule" />
  <div id="puzzleArea"></div>
  <div id="endState">
    <div class="end-score" id="endScore">Score: &mdash;/5</div>
    <div class="end-emojis" id="endEmojis"></div>
    <div class="end-buttons">
      <button class="copy-btn" id="copyBtn" onclick="copyResult()">Copy Result
</button>
    </div>
    <div class="countdown" id="countdown"></div>
  </div>
  <hr class="rule" />
  <footer>
    <a href="/magic">how does this work? &rarr;</a><br>
    christopherjharper.com
  </footer>
</div>

<script>
/* ── core chain logic ── */
const ONEs = ['zero','one','two','three','four','five','six','seven',
  'eight','nine','ten','eleven','twelve','thirteen','fourteen','fifteen',
  'sixteen','seventeen','nineteen','eighteen','nineteen'];
const TENs = ['','','twenty','thirty','forty','fifty','sixty','seventy','eighty','ninety'];

function toWords(n) {
  if (n < 0)    return 'negative ' + toWords(-n);
  if (n < 20)   return ONEs[n];
  if (n < 100)  { const t=TENs[Math.floor(n/10)],o=n%10; return o?t+'-'+ONEs[o
]:t; }
  if (n < 1000) { const h=Math.floor(n/100),r=n%100; return ONEs[h]+' hundred'
+(r?' '+toWords(r):''); }
  if (n < 10000){ const k=Math.floor(n/1000),r=n%1000; return toWords(k)+' thousand'+(r?' '+toWords(r):''); }
  return n.toString();
}

function letterCount(n) {
  return toWords(Math.abs(n)).replace(/[^a-z]/gi,'').length;
}

function buildChain(n) {
  const steps=[], seen=new Set();
  let cur=n;
  while(true) {
    if(seen.has(cur)||steps.length>30) break;
    seen.add(cur);
    const cnt=letterCount(cur);
    steps.push({value:cur, count:cnt});
    if(cnt===4) break;
    cur=cnt;
  }
  return steps;
}

/* ── seeded prng ── */
function mulberry32(seed) {
  return function() {
    seed |= 0; seed = seed + 0x6D2B79F5 | 0;
    let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

const EPOCH = new Date('2025-01-01T00:00:00Z').getTime();
function getDayNumber() { return Math.floor((Date.now() - EPOCH) / 86400000); 
}

function todayStr() {
  const d = new Date();
  return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String
(d.getDate()).padStart(2,'0');
}

const BLANK_PATTERNS = [[3,4],[1,4],[0,3],[0,2],[0,1]];

function generatePuzzle(dayNumber) {
  const rng = mulberry32(dayNumber * 1000003 + 7919);
  const candidates = [];
  for (let n = 10; n <= 9999; n++) {
    const chain = buildChain(n);
    if (chain.length < 6) continue;
    const usable = chain.filter(s => s.value !== 4);
    for (let start = 0; start <= usable.length - 5; start++) {
      const segment = usable.slice(start, start + 5).map(s => s.value);
      if (new Set(segment).size !== 5) continue;
      if (segment.includes(4)) continue;
      if (segment.some(v => v <= 0)) continue;
      if (Math.max(...segment) > 9999) continue;
      candidates.push(segment);
    }
  }
  const rows = [];
  const usedStarts = new Set();
  let attempts = 0;
  while (rows.length < 5 && attempts < 10000) {
    attempts++;
    const idx = Math.floor(rng() * candidates.length);
    const seg = candidates[idx];
    const key = seg[0];
    if (usedStarts.has(key)) continue;
    usedStarts.add(key);
    rows.push({ cells: seg, blanks: BLANK_PATTERNS[rows.length], difficulty: r
ows.length + 1 });
  }
  return rows;
}

/* ── validation ── */
function validateGuess(cells, blanks, index, guessedValue) {
  const left  = index > 0 ? cells[index - 1] : null;
  const right = index < 4 ? cells[index + 1] : null;
  let ok = true;
  if (left  !== null && !blanks.includes(index - 1)) ok = ok && (letterCount(l
eft) === guessedValue);
  if (right !== null && !blanks.includes(index + 1)) ok = ok && (letterCount(g
uessedValue) === right);
  return ok;
}

/* ── storage ── */
const STORAGE_KEY = () => 'four-puzzle-' + todayStr();
const ONBOARD_KEY = 'four-onboarded';
function loadState() { try { return JSON.parse(localStorage.getItem(STORAGE_KE
Y())); } catch(e) { return null; } }
function saveState(s) { try { localStorage.setItem(STORAGE_KEY(), JSON.stringi
fy(s)); } catch(e) {} }

/* ── game state ── */
let puzzle = [], rowStates = [], dayNumber = 0;

/* ── render ── */
function renderPuzzle() {
  const area = document.getElementById('puzzleArea');
  area.innerHTML = '';
  puzzle.forEach((row, ri) => {
    const rs = rowStates[ri];
    const rowEl = document.createElement('div');
    rowEl.className = 'puzzle-row'; rowEl.id = 'row-'+ri;
    const cellsWrap = document.createElement('div');
    cellsWrap.className = 'cells-wrap';
    row.cells.forEach((val, ci) => {
      if (ci > 0) {
        const arr = document.createElement('span');
        arr.className = 'arrow'; arr.textContent = '→';
        cellsWrap.appendChild(arr);
      }
      const cellEl = document.createElement('div');
      cellEl.className = 'cell'; cellEl.id = 'cell-'+ri+'-'+ci;
      const isBlank = row.blanks.includes(ci);
      if (rs.state === 'correct') {
        cellEl.classList.add('correct');
        cellEl.textContent = val;
      } else if (rs.state === 'revealed' && isBlank) {
        cellEl.classList.add('revealed');
        cellEl.textContent = val;
      } else if (!isBlank) {
        cellEl.textContent = val;
      } else {
        cellEl.classList.add('blank');
        const inp = document.createElement('input');
        inp.type = 'number'; inp.min = '1'; inp.max = '9999';
        inp.inputMode = 'numeric'; inp.pattern = '[0-9]*';
        inp.autocomplete = 'off'; inp.id = 'inp-'+ri+'-'+ci;
        inp.setAttribute('aria-label', 'Row '+(ri+1)+' blank '+(ci+1));
        if (rs.inputs && rs.inputs[ci] !== undefined) inp.value = rs.inputs[ci
];
        inp.addEventListener('blur', () => { if (inp.value) inp.value = parseI
nt(inp.value,10)||''; });
        inp.addEventListener('keydown', e => {
          if (e.key === 'Enter') {
            const bp = row.blanks; const myPos = bp.indexOf(ci);
            if (myPos === bp.length - 1) checkRow(ri);
            else { const ni = document.getElementById('inp-'+ri+'-'+bp[myPos+1
]); if(ni) ni.focus(); }
          }
        });
        inp.addEventListener('input', () => {
          if (!rowStates[ri].inputs) rowStates[ri].inputs = {};
          rowStates[ri].inputs[ci] = inp.value;
        });
        cellEl.appendChild(inp);
      }
      cellsWrap.appendChild(cellEl);
    });
    rowEl.appendChild(cellsWrap);
    const actions = document.createElement('div');
    actions.className = 'row-actions';
    if (rs.state === 'correct') {
      const ck = document.createElement('span'); ck.className = 'row-check'; c
k.textContent = '✓';
      actions.appendChild(ck);
    } else if (rs.state === 'revealed') {
      const lb = document.createElement('span');
      lb.style.cssText = 'font-size:0.6rem;color:var(--muted);letter-spacing:0.1em';
      lb.textContent = 'revealed'; actions.appendChild(lb);
    } else {
      const cb = document.createElement('button'); cb.className = 'btn btn-check'; cb.textContent = 'Check';
      cb.onclick = () => checkRow(ri); actions.appendChild(cb);
      if (rs.attempts > 0) {
        const rb = document.createElement('button'); rb.className = 'btn btn-reveal'; rb.textContent = 'Reveal';
        rb.onclick = () => revealRow(ri); actions.appendChild(rb);
      }
    }
    rowEl.appendChild(actions);
    area.appendChild(rowEl);
  });
  for (let ri = 0; ri < puzzle.length; ri++) {
    const rs = rowStates[ri];
    if (rs.state === 'pending' || rs.state === 'incorrect') {
      const fb = puzzle[ri].blanks[0];
      const inp = document.getElementById('inp-'+ri+'-'+fb);
      if (inp) setTimeout(() => inp.focus(), 100);
      break;
    }
  }
}

/* ── check row ── */
function checkRow(ri) {
  const row = puzzle[ri]; const rs = rowStates[ri];
  if (rs.state !== 'pending' && rs.state !== 'incorrect') return;
  const guesses = {};
  for (const ci of row.blanks) {
    const inp = document.getElementById('inp-'+ri+'-'+ci);
    const v = inp ? parseInt(inp.value, 10) : NaN;
    if (isNaN(v) || v < 1) { if(inp) inp.focus(); return; }
    guesses[ci] = v;
  }
  const cells = row.cells.slice();
  for (const ci of row.blanks) cells[ci] = guesses[ci];
  let allCorrect = true;
  const wrongIndices = [];
  for (const ci of row.blanks) {
    if (!validateGuess(cells, row.blanks, ci, guesses[ci])) { allCorrect = fal
se; wrongIndices.push(ci); }
  }
  if (allCorrect) {
    rs.state = 'correct'; rs.attempts++;
    const delay = 80;
    const cellEls = row.cells.map((_,ci) => document.getElementById('cell-'+ri
+'-'+ci)).filter(Boolean);
    cellEls.forEach((el,i) => setTimeout(() => el.classList.add('do-flip'), i*
delay));
    persistState();
    setTimeout(() => { renderPuzzle(); checkCompletion(); }, cellEls.length*de
lay + 440);
  } else {
    rs.state = 'incorrect'; rs.attempts++;
    for (const ci of wrongIndices) {
      const el = document.getElementById('cell-'+ri+'-'+ci);
      if (!el) continue;
      el.classList.remove('wrong-flash'); void el.offsetWidth; el.classList.ad
d('wrong-flash');
      setTimeout(() => el.classList.remove('wrong-flash'), 500);
    }
    persistState();
    setTimeout(() => renderPuzzle(), 0);
  }
}

/* ── reveal row ── */
function revealRow(ri) {
  rowStates[ri].state = 'revealed';
  persistState(); renderPuzzle(); checkCompletion();
}

/* ── completion ── */
function checkCompletion() {
  if (!rowStates.every(rs => rs.state === 'correct' || rs.state === 'revealed'
)) return;
  const s = buildStorageState(); s.completed = true; saveState(s); showEndStat
e(s);
}

function buildStorageState() {
  return {
    date: todayStr(),
    rowResults: rowStates.map(rs => {
      if (rs.state === 'correct' && rs.attempts === 1) return 'solved';
      if (rs.state === 'correct' && rs.attempts > 1) return 'solved-mistakes';
      if (rs.state === 'revealed') return 'failed';
      return 'pending';
    }),
    rowStateData: rowStates.map(rs => ({ state: rs.state, attempts: rs.attempt
s })),
    completed: false,
    score: rowStates.filter(rs => rs.state === 'correct').length,
  };
}

function persistState() { const s = buildStorageState(); saveState(s); }

/* ── end state ── */
function showEndState(savedState) {
  const results = savedState.rowResults || [];
  const score = results.filter(r => r === 'solved' || r === 'solved-mistakes')
.length;
  document.getElementById('endScore').textContent = 'Score: '+score+'/5';
  const emojis = results.map(r => r==='solved'?'�':r==='solved-mistakes'?'�':'�');
  document.getElementById('endEmojis').textContent = emojis.join('');
  document.getElementById('endState').classList.add('show');
  startCountdown();
}

function startCountdown() {
  function update() {
    const midnight = new Date(); midnight.setUTCHours(24,0,0,0);
    const diff = midnight.getTime() - Date.now();
    if (diff <= 0) { document.getElementById('countdown').textContent = 'New puzzle available now!'; return; }
    const h = Math.floor(diff/3600000);
    const m = Math.floor((diff%3600000)/60000);
    const s = Math.floor((diff%60000)/1000);
    document.getElementById('countdown').textContent =
      'Next puzzle in '+String(h).padStart(2,'0')+':'+String(m).padStart(2,'0'
)+':'+String(s).padStart(2,'0');
  }
  update(); setInterval(update, 1000);
}

function copyResult() {
  const results = (loadState()||{}).rowResults||[];
  const score = results.filter(r => r==='solved'||r==='solved-mistakes').lengt
h;
  const emojis = results.map(r => r==='solved'?'�':r==='solved-mistakes'?'�':'�').join('');
  const text = 'FOUR #'+dayNumber+'\n'+emojis+'\n'+score+'/5 · fourpuzzle.com'
;
  const btn = document.getElementById('copyBtn');
  const finish = () => {
    btn.textContent = 'Copied!'; btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy Result'; btn.classList.remove('copied'); }, 2000);
  };
  if (navigator.clipboard) navigator.clipboard.writeText(text).then(finish).ca
tch(() => legacyCopy(text,finish));
  else legacyCopy(text, finish);
}

function legacyCopy(text, cb) {
  const ta = document.createElement('textarea');
  ta.value = text; ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0';
  document.body.appendChild(ta); ta.select();
  try { document.execCommand('copy'); } catch(e) {}
  document.body.removeChild(ta); cb();
}

/* ── onboarding ── */
let miniExplored = false;
function miniExplore() {
  const inp = document.getElementById('miniNumInput');
  const n = parseInt(inp.value, 10);
  if (isNaN(n) || n <= 0) return;
  const chain = buildChain(n);
  const parts = chain.map(s => {
    const last = s.count === 4;
    return '<span class="'+(last?'magic':'num')+'">'+s.value+'</span> → <span class="'+(last?'magic':'num')+'">'+s.count+'</span>';
  });
  document.getElementById('miniResult').innerHTML = parts.join(' → ');
  if (!miniExplored) { miniExplored = true; document.getElementById('miniContinue').disabled = false; }
}
function goModalStep(step) {
  document.querySelectorAll('.modal-step').forEach(el => el.classList.remove('active'));
  document.getElementById('modalStep'+step).classList.add('active');
}
function answerQuiz(btn, correct) {
  btn.classList.remove('wrong-flash','correct-flash'); void btn.offsetWidth;
  if (correct) {
    btn.classList.add('correct-flash');
    document.getElementById('correctMsg').style.display = 'block';
    document.getElementById('playBtn').disabled = false;
  } else {
    btn.classList.add('wrong-flash');
  }
}
function dismissModal() {
  localStorage.setItem(ONBOARD_KEY, '1');
  const modal = document.getElementById('modal');
  modal.style.opacity = '0';
  setTimeout(() => { modal.style.display = 'none'; }, 350);
}
document.getElementById('miniNumInput').addEventListener('keydown', e => { if(
e.key==='Enter') miniExplore(); });

/* ── init ── */
function init() {
  dayNumber = getDayNumber();
  document.getElementById('dayNum').textContent = dayNumber;
  document.getElementById('dateLabel').textContent = todayStr();
  puzzle = generatePuzzle(dayNumber);
  const saved = loadState();
  if (saved && saved.completed) {
    rowStates = saved.rowStateData
      ? saved.rowStateData.map(d => ({ state: d.state, attempts: d.attempts, i
nputs: {} }))
      : puzzle.map((_,ri) => ({ state: (saved.rowResults[ri]==='failed'||saved
.rowResults[ri]==='pending')?'revealed':'correct', attempts: 1, inputs: {} })); 
    renderPuzzle(); showEndState(saved);
  } else if (saved && !saved.completed && saved.rowStateData) {
    rowStates = saved.rowStateData.map(d => ({ state: d.state, attempts: d.att
empts, inputs: {} }));
    renderPuzzle();
  } else {
    rowStates = puzzle.map(() => ({ state: 'pending', attempts: 0, inputs: {} 
}));
    renderPuzzle();
  }
  const onboarded = localStorage.getItem(ONBOARD_KEY);
  const modal = document.getElementById('modal');
  if (onboarded) { modal.style.display = 'none'; }
  else { requestAnimationFrame(() => modal.classList.add('visible')); }
}

init();
</script>
</body>
</html>